  "roles": {
    "apiVersion": "rbac.authorization.k8s.io/v1",
    "kind": "RoleList",
    "items": [
      {
        "metadata": { "name": "secret-reader", "namespace": "default" },
        "rules": [
          {
            "apiGroups": [""],
            "resources": ["secrets"],
            "verbs": ["get", "list", "watch"]
          }
        ]
      },
      {
        "metadata": { "name": "configmap-admin", "namespace": "production" },
        "rules": [
          {
            "apiGroups": [""],
            "resources": ["configmaps"],
            "verbs": ["*"]
          }
        ]
      },
      {
        "metadata": { "name": "pod-executor", "namespace": "production" },
        "rules": [
          {
            "apiGroups": [""],
            "resources": ["pods"],
            "verbs": ["get", "list", "watch"]
          },
          {
            "apiGroups": [""],
            "resources": ["pods/exec"],
            "verbs": ["create"]
          }
        ]
      },
      {
        "metadata": { "name": "backend-role", "namespace": "production" },
        "rules": [
          {
            "apiGroups": [""],
            "resources": ["secrets"],
            "verbs": ["get", "list", "update", "patch"]
          },
          {
            "apiGroups": [""],
            "resources": ["configmaps"],
            "verbs": ["get", "list", "update"]
          }
        ]
      },
      {
        "metadata": { "name": "monitoring-viewer", "namespace": "monitoring" },
        "rules": [
          {
            "apiGroups": [""],
            "resources": ["pods", "services", "endpoints"],
            "verbs": ["get", "list", "watch"]
          },
          {
            "apiGroups": [""],
            "resources": ["secrets"],
            "verbs": ["get"]
          }
        ]
      }
    ]
  },

  "clusterRoles": {
    "apiVersion": "rbac.authorization.k8s.io/v1",
    "kind": "ClusterRoleList",
    "items": [
      {
        "metadata": { "name": "cluster-admin" },
        "rules": [
          {
            "apiGroups": ["*"],
            "resources": ["*"],
            "verbs": ["*"]
          }
        ]
      },
      {
        "metadata": { "name": "api-cluster-role" },
        "rules": [
          {
            "apiGroups": [""],
            "resources": ["secrets", "configmaps"],
            "verbs": ["get", "list", "watch", "create", "update"]
          }
        ]
      },
      {
        "metadata": { "name": "secret-manager" },
        "rules": [
          {
            "apiGroups": [""],
            "resources": ["secrets"],
            "verbs": ["*"]
          }
        ]
      }
    ]
  },

