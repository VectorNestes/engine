# ─────────────────────────────────────────────────────────────────────────────
# Kubernetes Attack Path Visualizer — Environment Variables
# Copy this file and fill in your values. Never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Neo4j ─────────────────────────────────────────────────────────────────────
# Default values match the docker/docker-compose.yml container
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
